# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python

# PowerShell
*.ps1 text eol=crlf

# SQL
*.sql text

# JSON
*.json text

# YAML
*.yml text
*.yaml text

# Markdown
*.md text

# Shell scripts
*.sh text eol=lf

# Bat
*.bat text eol=crlf

# Binary
*.png binary
*.jpg binary
*.ico binary
*.pdf binary
